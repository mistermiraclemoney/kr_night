{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "node scripts/prepare-web.mjs"
  },
  "deploy": {
    "startCommand": "node --experimental-sqlite server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
