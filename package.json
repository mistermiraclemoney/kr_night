{
  "name": "kr-night-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "KR NIGHT mobile app shell powered by Capacitor.",
  "scripts": {
    "build": "node scripts/prepare-web.mjs",
    "start": "node server.js",
    "prepare:web": "node scripts/prepare-web.mjs",
    "cap:copy": "npm run prepare:web && cap copy",
    "cap:sync": "npm run prepare:web && cap sync",
    "cap:add:ios": "node scripts/add-ios-spm.mjs",
    "cap:open:ios": "npm run prepare:web && cap open ios",
    "cap:add:android": "cap add android",
    "cap:open:android": "npm run prepare:web && cap open android"
  },
  "dependencies": {
    "@capacitor/core": "^7.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.1",
    "@capacitor/ios": "^7.4.1",
    "@capacitor/android": "^7.4.1"
  }
}